{
  "name": "kwikbridge-lms",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 50",
    "lint:fix": "eslint src/ --fix",
    "check": "python3 check.py src/kwikbridge-lms-v2.jsx",
    "test": "python3 test_suite.py && python3 smoke_test.py && python3 data_validation_test.py",
    "test:all": "for f in *_test.py test_suite.py; do python3 $f; done",
    "ci": "npm run typecheck && npm run lint && npm run check && npm run build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "e2e:headless": "cypress run --headless --browser chrome",
    "test:component": "vitest run --config vitest.components.config.ts",
    "test:component:watch": "vitest --config vitest.components.config.ts",
    "test:all-vitest": "npm run test:unit && npm run test:component",
    "rls:analyse": "python3 scripts/security/analyse_rls.py",
    "rls:verify": "node scripts/security/verify_rls.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "cypress": "^13.17.0",
    "eslint": "^10.2.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}