{
  "name": "kwikbridge-lms",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 50",
    "lint:fix": "eslint src/ --fix",
    "check": "python3 check.py src/kwikbridge-lms-v2.jsx",
    "test": "python3 test_suite.py && python3 smoke_test.py && python3 data_validation_test.py",
    "test:all": "for f in *_test.py test_suite.py; do python3 $f; done",
    "ci": "npm run typecheck && npm run lint && npm run check && npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.0"
  }
}