# KwikBridge LMS — Environment Variables
# Copy to .env.local and fill in actual values
# NEVER commit .env.local to git

# ─── Supabase (Public — embedded in client) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase (Server-side only — NEVER in VITE_ vars) ───
# Used by Edge Functions via Deno.env.get()
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Sentry (Frontend Error Tracking) ───
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project
VITE_SENTRY_ENVIRONMENT=production

# ─── Analytics ───
VITE_POSTHOG_KEY=phc_your-key
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Application ───
VITE_APP_ENV=production
VITE_APP_VERSION=2.1.0
